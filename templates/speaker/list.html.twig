{% extends 'layouts/base.html.twig' %}

{% block metaTitle 'speakers.list.title'|trans %}

{% block body %}
    <div class="mb-6">
        <twig:Breadcrumb items="{{ breadcrumbItems }}" />
    </div>

    <div class="text-center mb-8">
        <h1 class="font-display font-bold text-3xl md:text-4xl text-ink tracking-tight mb-2">{{ 'speakers.list.title'|trans }}</h1>
        <div class="w-12 h-1 bg-accent rounded-full mx-auto"></div>
    </div>

    <twig:SearchForm placeholder="{{ 'speakers.search.placeholder'|trans }}" />

    <ul class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
        {% for speaker in speakers %}
            <li class="flex">
                <twig:SpeakerCard speaker="{{ speaker }}" url="{{ path('speaker_show', { 'slug': speaker.slug }) }}"/>
            </li>
        {% endfor %}
    </ul>

    <twig:MetaPagination meta="{{ meta }}" />
{% endblock %}
