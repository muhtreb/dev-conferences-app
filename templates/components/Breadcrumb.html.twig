<nav class="flex flex-wrap items-center text-sm text-ink-muted">
    <ol class="list-reset flex flex-wrap items-center">
        {% for item in this.breadcrumbItems %}
            {% if item.url %}
                <li>
                    <a
                        href="{{ item.url }}"
                        class="text-ink-muted hover:text-accent transition-colors"
                    >{{ item.name }}</a>
                </li>
                <li>
                    <span class="mx-2 text-ink-soft">/</span>
                </li>
            {% else %}
                <li class="text-ink font-medium">{{ item.name }}</li>
            {% endif %}
        {% endfor %}
    </ol>
</nav>
