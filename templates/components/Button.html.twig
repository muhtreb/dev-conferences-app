<{{ tag }}
    class="inline-flex items-center justify-center text-sm font-semibold bg-accent hover:bg-accent-hover text-white py-2.5 px-5 rounded-lg shadow-sm hover:shadow transition-all duration-200 ease-out focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-surface-muted"
    {% if tag == 'a' %}
        {% if href %}href="{{ href }}"{% endif %}
        {% if target %}target="{{ target }}"{% endif %}
    {% endif %}
>
    {% block content %}{% endblock %}
</{{ tag }}>
