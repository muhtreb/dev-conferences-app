<div class="{{ current ? 'bg-accent-soft ring-accent' : 'bg-surface ring-edge hover:ring-edge-strong' }} flex p-2 rounded-lg ring-1 cursor-pointer relative h-full flex-row w-full transition-all duration-200 ease-out">
    <div class="relative">
        <div class="relative w-24 aspect-video rounded-md overflow-hidden ring-1 ring-edge bg-surface-subtle">
            <img
                    src="{{ talk.images.thumbnail }}"
                    class="w-full h-full object-cover"
                    alt=""
            />
        </div>
        {% if talk.duration %}
            <p class="bg-ink/80 text-white px-1.5 py-0.5 text-xs font-medium rounded absolute bottom-1 left-1">
                {{ this.duration }}
            </p>
        {% endif %}
    </div>
    <div class="ml-2 flex items-center">
        <h2 class="text-sm font-medium {{ current ? 'text-accent' : 'text-ink' }}">
            <a href="{{ url }}" class="before:inset-0 before:absolute before:content-[''] hover:text-accent transition-colors">{{ talk.name }}</a>
        </h2>
    </div>
</div>
