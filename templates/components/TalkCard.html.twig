<div class="flex p-4 bg-surface ring-1 ring-edge rounded-xl shadow-card hover:shadow-card-hover hover:ring-edge-strong cursor-pointer relative h-full flex-col w-full transition-all duration-200 ease-out">
    {% if app.user %}
        <div class="absolute right-3 top-3 z-20">
            <twig:Like type="talk" id="{{ talk.id }}" name="{{ talk.name }}" :focusable="false" />
        </div>
    {% endif %}
    <div class="relative">
        <div class="relative w-full aspect-video rounded-lg overflow-hidden ring-1 ring-edge bg-surface-subtle">
            <img
                    src="{{ talk.images.thumbnail }}"
                    class="w-full h-full object-cover"
                    alt=""
            />
        </div>
        {% if talk.duration %}
            <p class="bg-ink/80 text-white px-1.5 py-0.5 text-xs font-medium rounded absolute bottom-2 left-2">
                {{ this.duration }}
            </p>
        {% endif %}
    </div>
    <div class="mt-3">
        {% if showEdition and talk.edition is defined and talk.edition %}
            <div class="flex items-center relative p-2 bg-surface-subtle rounded-lg hover:bg-accent-soft transition-colors mb-3 z-20">
                {% if talk.edition.thumbnailImageUrl %}
                    <div class="relative w-8 h-8 shrink-0 rounded-md overflow-hidden ring-1 ring-edge">
                        <img
                                src="{{ talk.edition.thumbnailImageUrl }}"
                                alt=""
                                class="w-full h-full object-cover"
                        />
                    </div>
                {% endif %}
                <div class="ml-2 text-sm text-ink-muted">
                    <a
                            href="{{ path('edition_show', { slug: talk.edition.slug }) }}"
                            title="{{ talk.edition.name }}"
                            class="before:inset-0 before:absolute before:content-[''] hover:text-accent transition-colors"
                            tabindex="-1"
                    >
                        {{ talk.edition.name }}
                    </a>
                </div>
            </div>
        {% endif %}

        <h2 class="font-display text-base font-semibold text-ink tracking-tight mb-2">
            <a href="{{ url }}" class="before:inset-0 before:absolute before:content-[''] hover:text-accent transition-colors">{{ talk.name }}</a>
        </h2>

        {% if showDate %}
            <div class="text-xs italic text-ink-soft">
                {{ this.date }}
            </div>
        {% endif %}

        {% if showSpeakers and this.hasSpeakers %}
            <div class="flex flex-col flex-wrap mt-4 gap-2">
                {% for speaker in talk.speakers %}
                    <div class="flex flex-row w-full">
                        <div class="flex items-center relative p-2 bg-surface-subtle rounded-lg hover:bg-accent-soft transition-colors w-full">
                            <div class="relative w-8 h-8 shrink-0">
                                {% if speaker.avatarUrl %}
                                    <img
                                            src="{{ speaker.avatarUrl }}"
                                            alt="{{ speaker.firstName }} {{ speaker.lastName }}"
                                            class="w-full h-full rounded-full ring-1 ring-edge object-cover"
                                    />
                                {% else %}
                                    <div class="h-full w-full rounded-full bg-accent-soft text-accent flex items-center justify-center">
                                        {{ ux_icon('lucide:user', { class: 'w-4 h-4' }) }}
                                    </div>
                                {% endif %}
                            </div>
                            <div class="ml-2 text-sm text-ink-muted">
                                <a
                                        href="{{ path('speaker_show', {slug: speaker.slug }) }}"
                                        title="{{ speaker.firstName }} {{ speaker.lastName }}"
                                        class="before:inset-0 before:absolute before:content-[''] hover:text-accent transition-colors"
                                        tabindex="-1"
                                >
                                    {{ speaker.firstName }} {{ speaker.lastName }}
                                </a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>
