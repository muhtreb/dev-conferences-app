<div class="flex items-center justify-center w-full mb-10">
    <div class="max-w-3xl w-full">
        <form method="GET" {% if action %}action="{{ action }}"{% endif %}>
            <label for="default-search" class="sr-only">{{ 'search.label'|trans }}</label>
            <div class="relative">
                <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none text-ink-soft">
                    {{ ux_icon('lucide:search', { class: 'w-5 h-5' }) }}
                </div>
                <input
                        type="search"
                        id="default-search"
                        name="query"
                        value="{{ app.request.query.get('query')|default('') }}"
                        class="block w-full py-3 pl-12 pr-32 text-sm text-ink placeholder:text-ink-soft bg-surface ring-1 ring-edge focus:ring-2 focus:ring-accent focus:outline-none rounded-full shadow-card transition-shadow"
                        placeholder="{{ placeholder|default('search.placeholder'|trans) }}"
                        required
                />
                <button
                        type="submit"
                        class="absolute right-1.5 top-1.5 bottom-1.5 inline-flex items-center justify-center px-5 text-sm font-semibold text-white bg-accent hover:bg-accent-hover rounded-full transition-colors"
                >
                    {{ 'search.button'|trans }}
                </button>
            </div>
        </form>
    </div>
</div>
