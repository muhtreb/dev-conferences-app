<!DOCTYPE html>
<html lang="{{ app.request.locale|split('_')[0] }}">
<head>
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
                new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
            j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
            'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-T6TP9X4L');</script>
    <!-- End Google Tag Manager -->

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-5X3WXWGLJH"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());

        gtag('config', 'G-5X3WXWGLJH');
    </script>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{% block metaTitle %}{{ 'seo.title'|trans }}{% endblock %} | devconf.net</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Montserrat:wght@500;600;700&display=swap"
          rel="stylesheet">
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}

    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}

    <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('build/apple-touch-icon.png') }}">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('build/favicon-32x32.png') }}">
    <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('build/favicon-16x16.png') }}">
    <link rel="manifest" href="{{ asset('build/site.webmanifest') }}">

    <meta name="description" content="{% block metaDescription %}{{ 'seo.meta_description'|trans }}{% endblock %}">
    <meta name="keywords" content="{% block metaKeywords %}{{ 'seo.meta_keywords'|trans }}{% endblock %}" />

    {% block metaSocialNetwork %}{% endblock %}

    <script>
        window.isAuthenticated = {{ app.user ? 'true' : 'false' }};
        window.jsonTranslationsUrl = '{{ url('bazinga_jstranslation_js', { '_format': 'json', 'locales': 'fr,en' }) }}';
    </script>
</head>
<body class="bg-surface-muted text-ink min-h-screen flex flex-col items-center font-sans">
<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-T6TP9X4L"
                  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->
<div class="flex w-full min-h-screen flex-col items-center" id="app">
    <a
        class="transition left-0 bg-accent text-white px-3 py-2 rounded-md absolute focus:relative -translate-y-16 focus:translate-y-0 z-50"
        href="#main"
    >
        {{ 'header.skip_to_content'|trans }}
    </a>
    <header class="sticky top-0 z-30 flex w-full bg-surface/80 backdrop-blur-md border-b border-edge justify-center">
        <div class="p-4 max-w-screen-2xl flex-grow w-full flex flex-row items-center justify-center">
            <burger-button class="md:hidden py-1 px-1 text-ink-muted hover:text-ink">
                {{ ux_icon('lucide:menu', { class: 'w-5 h-5' }) }}
            </burger-button>
            <div class="md:flex-initial flex-1 font-display font-bold text-xl text-center md:text-left z-40 tracking-tight">
                <a href="/" class="text-ink hover:text-accent transition-colors">devconf<span class="text-accent">.net</span></a>
            </div>
            <div class="md:flex-1 flex flex-row md:flex-row justify-center items-center">
                <nav class="hidden md:flex md:relative md:bg-transparent md:backdrop-blur-none md:items-center md:justify-start md:flex-1 md:w-auto md:h-auto md:p-0 md:ml-4 fixed inset-0 w-full h-full bg-surface/95 backdrop-blur-md flex-col items-center justify-center p-8 z-30" id="nav">
                    <ul class="flex flex-col md:flex-row items-center md:items-center justify-center gap-2 md:gap-0 w-full max-w-sm md:max-w-none md:w-auto">
                        <li class="w-full md:w-auto"><a class="block w-full text-center md:w-auto md:text-left px-4 py-3 md:py-2 md:mr-1 text-xl md:text-sm font-medium text-ink-muted hover:text-ink hover:bg-surface-subtle rounded-lg md:rounded-md transition-colors" href="{{ path('conference_list') }}">{{ 'header.conferences.title'|trans }}</a></li>
                        <li class="w-full md:w-auto"><a class="block w-full text-center md:w-auto md:text-left px-4 py-3 md:py-2 md:mr-1 text-xl md:text-sm font-medium text-ink-muted hover:text-ink hover:bg-surface-subtle rounded-lg md:rounded-md transition-colors" href="{{ path('edition_list') }}">{{ 'header.editions.title'|trans }}</a></li>
                        <li class="w-full md:w-auto"><a class="block w-full text-center md:w-auto md:text-left px-4 py-3 md:py-2 md:mr-1 text-xl md:text-sm font-medium text-ink-muted hover:text-ink hover:bg-surface-subtle rounded-lg md:rounded-md transition-colors" href="{{ path('speaker_list') }}">{{ 'header.speakers.title'|trans }}</a></li>
                        <li class="w-full md:w-auto"><a class="block w-full text-center md:w-auto md:text-left px-4 py-3 md:py-2 text-xl md:text-sm font-medium text-ink-muted hover:text-ink hover:bg-surface-subtle rounded-lg md:rounded-md transition-colors" href="{{ path('talk_list') }}">{{ 'header.talks.title'|trans }}</a></li>
                    </ul>
                </nav>
                <div class="flex items-center justify-center gap-1 z-40 ml-auto">
                    <search-button>
                        <a href="{{ path('search') }}" id="header_search_button" title="{{ 'header.search.title'|trans }}" class="flex items-center justify-center w-9 h-9 rounded-full text-ink-muted hover:text-ink hover:bg-surface-subtle transition-colors">
                            {{ ux_icon('lucide:search', { class: 'w-5 h-5' }) }}
                        </a>
                    </search-button>
                    {% if app.user %}
                        <user-dropdown email="{{ app.user.email }}"></user-dropdown>
                    {% else %}
                        <a href="{{ path('security_login') }}" title="{{ 'header.login.title'|trans }}" class="flex items-center justify-center w-9 h-9 rounded-full text-ink-muted hover:text-ink hover:bg-surface-subtle transition-colors">
                            {{ ux_icon('lucide:user', { class: 'w-5 h-5' }) }}
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </header>

    <div id="search-form" class="fixed top-0 left-0 w-full h-full bg-surface/95 backdrop-blur-md z-50 flex justify-center items-center hidden">
        <div class="absolute top-0 right-0 p-4">
            <button id="search-form-close-button" class="flex items-center justify-center w-10 h-10 rounded-full text-ink-muted hover:text-ink hover:bg-surface-subtle transition-colors" aria-label="{{ 'search.close'|trans }}">
                {{ ux_icon('lucide:x', { class: 'w-6 h-6' }) }}
            </button>
        </div>
        <section class="w-full">
            <h2 class="font-bold text-3xl mb-8 text-center">{{ 'home.search.title'|trans }}</h2>
            <twig:SearchForm action="{{ path('search') }}" />
        </section>
    </div>

    <main class="px-4 py-4 max-w-screen-2xl flex-grow w-full" id="main">
        {% block body %}{% endblock %}
    </main>
    <footer class="mt-16 px-4 py-8 bg-surface border-t border-edge w-full text-center text-sm text-ink-muted">
        <p>
            Développé par <a class="font-semibold text-ink hover:text-accent transition-colors" href="https://github.com/muhtreb" target="_blank" rel="noreferrer"
                         title="{{ 'footer.github'|trans }}">muhtreb</a>
        </p>

        <ul class="mt-3 flex justify-center items-center gap-4">
            <li>
                <a href="https://twitter.com/devconfnet" class="inline-flex items-center justify-center w-8 h-8 rounded-full text-ink-soft hover:text-ink hover:bg-surface-subtle transition-colors" target="_blank" rel="noreferrer">
                    {{ ux_icon('simple-icons:x', { class: 'w-4 h-4' }) }}
                </a>
            </li>
            <li class="text-ink-soft">·</li>
            <li>
                <a href="{{ path('about') }}" class="hover:text-ink transition-colors">{{ 'footer.about'|trans }}</a>
            </li>
            <li class="text-ink-soft">·</li>
            <li>
                <a href="{{ path('rss_editions') }}" class="hover:text-ink transition-colors">{{ 'rss.editions'|trans }}</a>
            </li>
        </ul>
    </footer>
</div>
</body>
</html>
