{% extends 'layouts/base.html.twig' %}

{% block metaTitle 'conferences.list.title'|trans %}

{% block body %}
    <div class="mb-6">
        <twig:Breadcrumb items="{{ breadcrumbItems }}" />
    </div>

    <div class="text-center mb-8">
        <h1 class="font-display font-bold text-3xl md:text-4xl text-ink tracking-tight mb-2">{{ 'conferences.list.title'|trans }}</h1>
        <div class="w-12 h-1 bg-accent rounded-full mx-auto"></div>
    </div>

    <twig:SearchForm placeholder="Rechercher une conférence"/>

    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 xl:grid-cols-5 gap-4">
        {% for conference in conferences %}
            <li class="flex">
                <twig:ConferenceCard conference="{{ conference }}"
                                     url="{{ path('conference_show', { 'slug': conference.slug }) }}"/>
            </li>
        {% endfor %}
    </ul>

    <twig:MetaPagination meta="{{ meta }}" />
{% endblock %}
