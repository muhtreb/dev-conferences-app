{% extends 'layouts/base.html.twig' %}

{% block title 'login.title'|trans %}

{% block body %}
    <div class="max-w-md mx-auto mt-12 mb-16">
        <div class="text-center mb-12">
            <h1 class="font-display font-bold text-3xl md:text-4xl text-ink tracking-tight mb-2">
                {{ 'login.title'|trans }}
            </h1>
            <div class="w-12 h-1 bg-accent rounded-full mx-auto"></div>
        </div>

        <div class="bg-surface ring-1 ring-edge rounded-2xl shadow-card p-6 md:p-8">
            <h2 class="font-display font-semibold text-lg text-ink mb-4">
                {{ 'login.oauth.title'|trans }}
            </h2>
            <a
                href="{{ path('hwi_oauth_service_redirect', {'service': 'github' }) }}"
                class="w-full inline-flex items-center justify-center gap-2 bg-ink hover:bg-ink-muted text-white font-semibold text-sm py-2.5 px-4 rounded-lg transition-colors"
            >
                {{ ux_icon('simple-icons:github', { class: 'w-4 h-4' }) }}
                {{ 'login.oauth.github_button'|trans }}
            </a>

            <div class="relative my-8 flex items-center">
                <div class="flex-grow border-t border-edge"></div>
                <span class="mx-4 text-xs uppercase tracking-wide text-ink-soft">{{ 'login.email_link.title'|trans }}</span>
                <div class="flex-grow border-t border-edge"></div>
            </div>

            <form action="{{ path('security_login') }}" method="POST" class="flex flex-col">
                <p class="text-sm text-ink-muted mb-6">{{ 'login.email_link.description'|trans }}</p>
                <div class="flex flex-col mb-4 w-full">
                    {{ form_label(form.email, 'login.email.label', {
                        label_attr: {
                            'class': 'mb-2 text-sm font-medium text-ink'
                        }
                    }) }}
                    {{ form_widget(form.email, {
                        attr: {
                            'class': 'block w-full px-3 py-2 text-sm text-ink placeholder:text-ink-soft bg-surface ring-1 ring-edge focus:ring-2 focus:ring-accent focus:outline-none rounded-lg transition-shadow'
                        }
                    }) }}
                </div>
                <button
                    type="submit"
                    class="w-full inline-flex items-center justify-center text-sm font-semibold bg-accent hover:bg-accent-hover text-white py-2.5 px-5 rounded-lg shadow-sm hover:shadow transition-all duration-200 ease-out focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-surface"
                >
                    {{ 'login.email_link.button'|trans }}
                </button>
                {{ form_rest(form) }}
            </form>
        </div>
    </div>
{% endblock %}
