<h2 class="font-display font-bold text-2xl md:text-3xl mb-2 text-center text-ink tracking-tight">{{ 'home.latest_editions.title'|trans }}</h2>
<div class="w-12 h-1 bg-accent rounded-full mx-auto mb-10"></div>
<ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    {% for edition in editions %}
        <li class="flex">
            <twig:EditionCard
                    edition="{{ edition }}"
                    url="{{ url('edition_show', { slug: edition.slug }) }}"
                    showThumbnail
            />
        </li>
    {% endfor %}
</ul>
<div class="mt-10 flex items-center justify-center w-full">
    <twig:Button tag="a" href="{{ path('edition_list') }}">
        {{ 'home.latest_editions.button'|trans }}
    </twig:Button>
</div>