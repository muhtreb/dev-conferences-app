{% extends 'layouts/base.html.twig' %}

{% block metaTitle 'talks.list.title'|trans %}

{% block body %}
    <div class="mb-6">
        <twig:Breadcrumb items="{{ breadcrumbItems }}" />
    </div>

    <div class="text-center mb-8">
        <h1 class="font-display font-bold text-3xl md:text-4xl text-ink tracking-tight mb-2">{{ 'talks.list.title'|trans }}</h1>
        <div class="w-12 h-1 bg-accent rounded-full mx-auto"></div>
    </div>

    <twig:SearchForm placeholder="Rechercher une conférence" />

    <ul class="grid sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {% for talk in talks %}
            <li class="flex">
                <twig:TalkCard talk="{{ talk }}" url="{{ path('talk_show', { 'slug': talk.slug }) }}" showDate />
            </li>
        {% endfor %}
    </ul>

    <twig:MetaPagination meta="{{ meta }}" />
{% endblock %}
