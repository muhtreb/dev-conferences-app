{% extends 'layouts/base.html.twig' %}

{% block metaTitle talk.name ~ ' | ' ~ edition.name %}

{% block metaSocialNetwork %}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ talk.name }}" />
    <meta name="twitter:description" content="{{ talk.description }}" />
    {% if talk.images.thumbnail %}
        <meta name="twitter:image" content="{{ talk.images.thumbnail }}" />
        <meta name="twitter:image:alt" content="{{ talk.name }}" />
    {% endif %}
    <meta property="og:title" content="{{ talk.name }}" />
    <meta property="og:description" content="{{ talk.description }}" />
    <meta property="og:type" content="website" />
    {% if talk.images.thumbnail %}
        <meta property="og:image" content="{{ talk.images.thumbnail }}" />
    {% endif %}
{% endblock %}

{% set hasSpeakers = talk.speakers|length > 0 %}

{% block body %}
    <div class="mb-6">
        <twig:Breadcrumb items="{{ breadcrumbItems }}" />
    </div>

    <div class="flex flex-col md:flex-row gap-4">
        <div class="flex-grow">
            <div class="flex {{ hasSpeakers ? "flex-col md:flex-row " : "" }}" id="video-container" data-talk-id="{{ talk.id }}">
                <div class="relative flex-1 aspect-video rounded-2xl overflow-hidden ring-1 ring-edge shadow-card">
                    <iframe
                            class="absolute inset-0 w-full h-full"
                            src="https://www.youtube.com/embed/{{ talk.youtubeId }}"
                            allowfullscreen
                            allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
                    ></iframe>
                </div>
            </div>
        </div>
        <div class="flex-shrink-0 md:max-w-xs lg:max-w-sm w-full mt-4 md:mt-0 p-4 bg-surface ring-1 ring-edge rounded-2xl shadow-card h-96" id="playlist-container">
            <nav class="flex flex-col h-full">
                <h2 class="mb-4 font-display text-xl font-bold text-ink tracking-tight">Talks</h2>
                <ul class="overflow-y-auto overflow-x-hidden flex-grow space-y-2 pr-1">
                    {% for playlistTalk in edition.talks %}
                        <li data-playlist-talk-id="{{ playlistTalk.id }}">
                            <twig:TalkCardHorizontal talk="{{ playlistTalk }}" url="{{ path('talk_show', { slug: playlistTalk.slug }) }}" :showEdition="false" :current="playlistTalk.id == talk.id" />
                        </li>
                    {% endfor %}
                </ul>
            </nav>
        </div>
    </div>

    <div>
        <div class="flex mt-6 gap-4 {{ hasSpeakers ? "flex-col md:flex-row " : "" }}">
            <div class="p-6 flex-1 bg-surface ring-1 ring-edge rounded-2xl shadow-card leading-7 text-sm">
                <div class="flex items-start justify-between gap-4 mb-4">
                    <h1 class="font-display font-bold text-2xl md:text-3xl text-ink tracking-tight">{{ talk.name }}</h1>
                    {% if app.user %}
                        <div class="shrink-0">
                            <twig:Like type="talk" id="{{ talk.id }}" name="{{ talk.name }}" />
                        </div>
                    {% endif %}
                </div>
                {% if talk.description %}
                    <p class="break-words text-ink-muted">{{ talk.description }}</p>
                {% endif %}
                <div class="text-sm italic mt-4 text-ink-soft">
                    {{ talk.date|format_datetime('long', 'none') }}
                </div>
            </div>
            {% if hasSpeakers %}
                <div class="w-full md:w-64 shrink-0">
                    <div class="space-y-4">
                        {% for speaker in talk.speakers %}
                            <twig:SpeakerCard speaker="{{ speaker }}" url="{{ path('speaker_show', { slug: speaker.slug }) }}"/>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
