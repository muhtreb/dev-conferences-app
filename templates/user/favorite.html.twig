{% extends 'layouts/base.html.twig' %}

{% block metaTitle 'user.favorite.title'|trans %}

{% block body %}
    <div class="text-center mb-4 mt-4">
        <h1 class="font-display font-bold text-3xl md:text-4xl text-ink tracking-tight mb-2">{{ 'user.favorite.title'|trans }}</h1>
        <div class="w-12 h-1 bg-accent rounded-full mx-auto"></div>
    </div>

    <p class="mb-12 text-center text-ink-muted">
        {{ 'user.favorite.description'|trans }}
    </p>

    {% if conferences|length %}
        <section class="mb-16">
            <h2 class="font-display font-semibold text-xl md:text-2xl text-ink tracking-tight mb-6">{{ 'user.favorite.conferences.title'|trans({ count: conferences|length }) }}</h2>

            <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 xl:grid-cols-5 gap-4">
                {% for conference in conferences %}
                    <li class="flex">
                        <twig:ConferenceCard conference="{{ conference }}"
                                             url="{{ path('conference_show', { 'slug': conference.slug }) }}"/>
                    </li>
                {% endfor %}
            </ul>
        </section>
    {% endif %}

    {% if editions|length %}
        <section class="mb-16">
            <h2 class="font-display font-semibold text-xl md:text-2xl text-ink tracking-tight mb-6">{{ 'user.favorite.editions.title'|trans({ count: editions|length }) }}</h2>

            <ul class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
                {% for edition in editions %}
                    <li class="flex">
                        <twig:EditionCard edition="{{ edition }}"
                                          url="{{ path('edition_show', { 'slug': edition.slug }) }}" showThumbnail />
                    </li>
                {% endfor %}
            </ul>
        </section>
    {% endif %}

    {% if talks|length %}
        <section class="mb-16">
            <h2 class="font-display font-semibold text-xl md:text-2xl text-ink tracking-tight mb-6">{{ 'user.favorite.talks.title'|trans({ count: talks|length }) }}</h2>

            <ul class="grid sm:grid-cols-3 lg:grid-cols-4 gap-4">
                {% for talk in talks %}
                    <li class="flex">
                        <twig:TalkCard talk="{{ talk }}" url="{{ path('talk_show', { 'slug': talk.slug }) }}"/>
                    </li>
                {% endfor %}
            </ul>
        </section>
    {% endif %}

    {% if speakers|length %}
        <section>
            <h2 class="font-display font-semibold text-xl md:text-2xl text-ink tracking-tight mb-6">{{ 'user.favorite.speakers.title'|trans({ count: speakers|length }) }}</h2>

            <ul class="grid grid-cols-2 lg:grid-cols-4 xl:grid-cols-5 gap-4">
                {% for speaker in speakers %}
                    <li class="flex">
                        <twig:SpeakerCard speaker="{{ speaker }}"
                                          url="{{ path('speaker_show', { 'slug': speaker.slug }) }}"/>
                    </li>
                {% endfor %}
            </ul>
        </section>
    {% endif %}
{% endblock %}
