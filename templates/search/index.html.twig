{% extends 'layouts/base.html.twig' %}

{% block metaTitle 'search.title'|trans %}

{% set query = app.request.query.get('query') %}

{% block body %}
    <div class="mb-6">
        <twig:Breadcrumb items="{{ breadcrumbItems }}" />
    </div>

    <div class="text-center mb-8">
        <h1 class="font-display font-bold text-3xl md:text-4xl text-ink tracking-tight mb-2">
            {{ 'search.title'|trans }}
        </h1>
        <div class="w-12 h-1 bg-accent rounded-full mx-auto"></div>
    </div>

    <twig:SearchForm />

    {% if conferences|length %}
        <section class="mb-16">
            <h2 class="font-display font-semibold text-xl md:text-2xl text-ink tracking-tight mb-6">{{ 'search.conferences.title'|trans }}</h2>

            <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 xl:grid-cols-5 gap-4">
                {% for conference in conferences %}
                    <li class="flex">
                        <twig:ConferenceCard conference="{{ conference }}"
                                             url="{{ path('conference_show', { 'slug': conference.slug }) }}"/>
                    </li>
                {% endfor %}
            </ul>

            {% if conferencesMeta.nextPage %}
                <div class="mt-8 flex items-center justify-center">
                    <twig:Button href="{{ path('conference_list', { query: query }) }}" tag="a">
                        {{ 'search.conferences.more'|trans({ query: query ? '"' ~ query ~ '"' : '' }) }}
                    </twig:Button>
                </div>
            {% endif %}
        </section>
    {% endif %}

    {% if editions|length %}
        <section class="mb-16">
            <h2 class="font-display font-semibold text-xl md:text-2xl text-ink tracking-tight mb-6">{{ 'search.editions.title'|trans }}</h2>

            <ul class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
                {% for edition in editions %}
                    <li class="flex">
                        <twig:EditionCard edition="{{ edition }}"
                                          url="{{ path('edition_show', { 'slug': edition.slug }) }}" showThumbnail />
                    </li>
                {% endfor %}
            </ul>

            {% if editionsMeta.nextPage %}
                <div class="mt-8 flex items-center justify-center">
                    <twig:Button href="{{ path('edition_list', { query: query }) }}" tag="a">
                        {{ 'search.editions.more'|trans({ query: query ? '"' ~ query ~ '"' : '' }) }}
                    </twig:Button>
                </div>
            {% endif %}
        </section>
    {% endif %}

    {% if talks|length %}
        <section class="mb-16">
            <h2 class="font-display font-semibold text-xl md:text-2xl text-ink tracking-tight mb-6">{{ 'search.talks.title'|trans }}</h2>

            <ul class="grid sm:grid-cols-3 lg:grid-cols-4 gap-4">
                {% for talk in talks %}
                    <li class="flex">
                        <twig:TalkCard talk="{{ talk }}" url="{{ path('talk_show', { 'slug': talk.slug }) }}" showDate />
                    </li>
                {% endfor %}
            </ul>

            {% if talksMeta.nextPage %}
                <div class="mt-8 flex items-center justify-center">
                    <twig:Button href="{{ path('talk_list', { query: query }) }}" tag="a">
                        {{ 'search.talks.more'|trans({ query: query ? '"' ~ query ~ '"' : '' }) }}
                    </twig:Button>
                </div>
            {% endif %}
        </section>
    {% endif %}

    {% if speakers|length %}
        <section class="mb-16">
            <h2 class="font-display font-semibold text-xl md:text-2xl text-ink tracking-tight mb-6">{{ 'search.speakers.title'|trans }}</h2>

            <ul class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
                {% for speaker in speakers %}
                    <li class="flex">
                        <twig:SpeakerCard speaker="{{ speaker }}"
                                          url="{{ path('speaker_show', { 'slug': speaker.slug }) }}"/>
                    </li>
                {% endfor %}
            </ul>

            {% if speakersMeta.nextPage %}
                <div class="mt-8 flex items-center justify-center">
                    <twig:Button href="{{ path('speaker_list', { query: query }) }}" tag="a">
                        {{ 'search.speakers.more'|trans({ query: query ? '"' ~ query ~ '"' : '' }) }}
                    </twig:Button>
                </div>
            {% endif %}
        </section>
    {% endif %}

    {% if speakers|length == 0 and conferences|length == 0 and editions|length == 0 and talks|length == 0 %}
        <section class="flex flex-col items-center justify-center text-center py-16">
            <div class="w-16 h-16 rounded-full bg-accent-soft text-accent flex items-center justify-center mb-4">
                {{ ux_icon('lucide:search', { class: 'w-7 h-7' }) }}
            </div>
            <p class="font-display font-semibold text-xl text-ink mb-2">
                {{ 'search.no_results.title'|trans({ query }) }}
            </p>
        </section>
    {% endif %}
{% endblock %}
